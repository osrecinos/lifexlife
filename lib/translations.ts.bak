/* ── ENGINE ── */
const LXL_I18N = {
  lang: 'es',

  detect() {
    const saved = localStorage.getItem('lxl-lang');
    if (saved) { this.lang = saved; return; }
    const browser = (navigator.language || navigator.userLanguage || 'es').toLowerCase();
    this.lang = browser.startsWith('en') ? 'en' : 'es';
    localStorage.setItem('lxl-lang', this.lang);
  },

  t(section, key) {
    const s = LXL_TRANSLATIONS[section];
    if (!s) return '';
    const entry = s[key];
    if (!entry) return '';
    return entry[this.lang] || entry['es'] || '';
  },

  apply() {
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const [section, key] = el.getAttribute('data-i18n').split('.');
      const val = this.t(section, key);
      if (val) el.innerHTML = val;
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const [section, key] = el.getAttribute('data-i18n-placeholder').split('.');
      const val = this.t(section, key);
      if (val) el.placeholder = val;
    });
    // Update lang toggle button
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.textContent = this.lang === 'es' ? 'EN' : 'ES';
      btn.title = this.lang === 'es' ? 'Switch to English' : 'Cambiar a Español';
    });
    // Update html lang
    document.documentElement.lang = this.lang;
  },

  toggle() {
    this.lang = this.lang === 'es' ? 'en' : 'es';
    localStorage.setItem('lxl-lang', this.lang);
    this.apply();
  },

  init() {
    this.detect();
    this.apply();
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => this.toggle());
    });
  }
};
